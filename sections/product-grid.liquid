
{% style %}
.product-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  padding: 40px;
}

.product-card {
  border: 1px solid #eee;
  padding: 10px;
  cursor: pointer;
  text-align: center;
  transition: 0.3s;
  position: relative;
  overflow: hidden;
}

.product-card:hover {
  transform: scale(1.03);
}

.product-card img {
  width: 100%;
  height: auto;
}

/* Overlay*/
.overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.4);

  display: flex;
  justify-content: center;
  align-items: center;

  opacity: 0;
  visibility: hidden;
  transition: 0.3s;
}
 
.product-card:hover .overlay {
  opacity: 1;
  visibility: visible;
}

.overlay button {
  background: white;
  padding: 8px 12px;
  border: none;
  cursor: pointer;
}

/* Popup */
#product-popup {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.7);
  z-index: 9999;
}

.popup-content {
  background: white;
  max-width: 400px;
  margin: 50px auto;
  padding: 20px;
  position: relative;
  text-align: center;
  max-height: 90vh;
  overflow-y: auto;
}

.close-btn {
  position: absolute;
  right: 10px;
  top: 10px;
  cursor: pointer;
}

.popup-content img {
  width: 100%;
  height: auto;
  margin-bottom: 10px;
}

/* ================= MOBILE FIX ================= */
@media (max-width: 768px) {

  .product-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    padding: 15px;
  }

  .product-card h3 {
    font-size: 14px;
    line-height: 1.3;
    word-break: break-word;
    white-space: normal;
  }

  .product-card {
    padding: 8px;
  }
}
{% endstyle %}

<!-- PRODUCT GRID -->
<div class="product-grid">
  {% for block in section.blocks %}
    {% assign product = all_products[block.settings.product] %}

    {% if product != blank %}
      <div class="product-card" onclick="openProductPopup('{{ product.handle }}')">

        <img 
          src="{{ product.featured_image | image_url: width: 600 }}" 
          alt="{{ product.title }}"
          width="300"
          height="300"
        >

        <div class="overlay">
          <button>Shop Now</button>
        </div>

        <h3>{{ product.title }}</h3>
        <p>{{ product.price | money }}</p>

      </div>
    {% endif %}
  {% endfor %}
</div>

<!-- POPUP -->
<div id="product-popup">
  <div class="popup-content">

    <span class="close-btn" onclick="closePopup()">X</span>

    <img id="popup-image" width="400" height="400">
    <h2 id="popup-title"></h2>
    <p id="popup-price"></p>
    <p id="popup-description"></p>

    <select id="variant-select"></select>

    <br><br>

    <input type="number" id="quantity" value="1" min="1">

    <br><br>

    <button onclick="addToCart()">Add to Cart</button>

  </div>
</div>

<!-- JS -->
<script>
let currentProduct = null;

function openProductPopup(handle) {

  fetch(`/products/${handle}.js`)
    .then(res => res.json())
    .then(product => {

      currentProduct = product;

      document.getElementById("product-popup").style.display = "block";

      document.getElementById("popup-title").innerText = product.title;
      document.getElementById("popup-price").innerText = "₹" + (product.price / 100);
      document.getElementById("popup-description").innerHTML = product.description;
      document.getElementById("popup-image").src = product.images[0];

      let select = document.getElementById("variant-select");
      select.innerHTML = "";

      product.variants.forEach(v => {
        let opt = document.createElement("option");
        opt.value = v.id;
        opt.text = v.title;
        select.appendChild(opt);
      });
    });
}

function closePopup() {
  document.getElementById("product-popup").style.display = "none";
}

function addToCart() {

  let select = document.getElementById("variant-select");
  let variantId = select.value;
  let variantText = select.options[select.selectedIndex].text;
  let qty = document.getElementById("quantity").value;

  let items = [{
    id: variantId,
    quantity: qty
  }];

  // RULE: Black + Medium → auto add Soft Winter Jacket
  if (variantText.includes("Black") && variantText.includes("M")) {
    items.push({
      id: 43935936381025,
      quantity: 1
    });
  }

  fetch('/cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ items: items })
  })
  .then(res => res.json())
  .then(() => {
    alert("Added to cart!");
    closePopup();
    window.location.href = "/cart";
  })
  .catch(err => console.log(err));
}
</script>

{% schema %}
{
  "name": "Product Grid",
  "settings": [],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Product Grid"
    }
  ]
}
{% endschema %}